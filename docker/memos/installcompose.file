# Memos - 轻量笔记服务
#
# 安装: docker compose up -d
# 访问: http://localhost:5230
# 默认: 首次访问注册即可

services:
  memos:
    image: neosmemo/memos:stable
    container_name: memos
    ports:
      - "5230:5230"
    volumes:
      - ./data:/var/opt/memos
    restart: unless-stopped
    environment:
      - MEMOS_DRIVER=sqlite
      - MEMOS_MODE=prod
