version: '3.8'

services:
  calibre-web:
    image: linuxserver/calibre-web:latest
    container_name: calibre-web
    restart: always
    environment:
      PUID: 1000
      PGID: 1000
      TZ: Asia/Shanghai
      DOCKER_MODS: linuxserver/mods:universal-calibre
    ports:
      - "8083:8083"
    volumes:
      - ./calibre-data:/config
      - ./calibre-books:/books
    networks:
      - calibre-net

networks:
  calibre-net:
    driver: bridge
