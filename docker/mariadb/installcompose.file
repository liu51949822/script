version: '3.8'

services:
  mariadb:
    image: mariadb:11.4
    container_name: mariadb-server
    restart: always
    environment:
      MARIADB_ROOT_PASSWORD: your_root_password
      MARIADB_DATABASE: mydb
      MARIADB_USER: myuser
      MARIADB_PASSWORD: your_user_password
    ports:
      - "3307:3306"
    volumes:
      - ./mariadb-data:/var/lib/mysql
      - ./mariadb-conf/my.cnf:/etc/mysql/conf.d/my.cnf:ro
    networks:
      - mariadb-net

networks:
  mariadb-net:
    driver: bridge
