version: '3.8'

services:
  stirling-pdf:
    image: frooodle/s-pdf:latest
    container_name: stirling-pdf
    restart: always
    environment:
      DOCKER_ENABLE_SECURITY: "false"
      INSTALL_BOOK_AND_ADVANCED_HTML_OPS: "false"
      LANGS: zh_CN
    ports:
      - "8080:8080"
    volumes:
      - ./stirling-trainingData:/usr/share/tessdata
      - ./stirling-extraConfigs:/configs
      - ./stirling-logs:/logs
    networks:
      - spdf-net

networks:
  spdf-net:
    driver: bridge
