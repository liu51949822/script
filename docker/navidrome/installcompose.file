version: '3.8'

services:
  navidrome:
    image: deluan/navidrome:latest
    container_name: navidrome
    restart: always
    environment:
      ND_LOGLEVEL: info
      ND_SESSIONTIMEOUT: 24h
      ND_BASEURL: ""
      TZ: Asia/Shanghai
    ports:
      - "4533:4533"
    volumes:
      - ./navidrome-data:/data
      - ./navidrome-music:/music:ro
    networks:
      - navidrome-net

networks:
  navidrome-net:
    driver: bridge
