version: '3.8'

services:
  cockroachdb:
    image: cockroachdb/cockroach:latest
    container_name: cockroachdb
    restart: always
    environment:
      COCKROACH_USER: root
    ports:
      - "26257:26257"
      - "8080:8080"
    volumes:
      - ./cockroach-data:/cockroach/cockroach-data
    networks:
      - crdb-net
    command: start-single-node --insecure

networks:
  crdb-net:
    driver: bridge
