version: '3.8'

services:
  dozzle:
    image: amir20/dozzle:latest
    container_name: dozzle
    restart: always
    environment:
      DOZZLE_HOSTNAME: my-server
    ports:
      - "8888:8080"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks:
      - dozzle-net

networks:
  dozzle-net:
    driver: bridge
