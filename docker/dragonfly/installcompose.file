version: '3.8'

services:
  dragonfly:
    image: docker.dragonflydb.io/dragonflydb/dragonfly:latest
    container_name: dragonfly
    restart: always
    environment:
      DFLY_requirepass: your_secure_password
    ports:
      - "6379:6379"
    volumes:
      - ./dragonfly-data:/data
    networks:
      - df-net
    ulimits:
      memlock:
        soft: -1
        hard: -1

networks:
  df-net:
    driver: bridge
