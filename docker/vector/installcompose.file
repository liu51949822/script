version: '3.8'

services:
  vector:
    image: timberio/vector:latest-alpine
    container_name: vector
    restart: always
    ports:
      - "8686:8686"
    volumes:
      - ./vector-config/vector.toml:/etc/vector/vector.toml:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /var/log:/var/log:ro
    networks:
      - vector-net

networks:
  vector-net:
    driver: bridge
