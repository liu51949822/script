version: '3.8'

services:
  authelia:
    image: authelia/authelia:latest
    container_name: authelia
    restart: always
    environment:
      TZ: Asia/Shanghai
    ports:
      - "9091:9091"
    volumes:
      - ./authelia-conf:/config
    networks:
      - authelia-net

networks:
  authelia-net:
    driver: bridge
