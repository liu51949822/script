version: '3.8'

services:
  freshrss:
    image: freshrss/freshrss:latest
    container_name: freshrss
    restart: always
    environment:
      TZ: Asia/Shanghai
      CRON_MIN: '*/30'
    ports:
      - "8282:80"
    volumes:
      - ./freshrss-data:/var/www/FreshRSS/data
      - ./freshrss-extensions:/var/www/FreshRSS/extensions
    networks:
      - frss-net

networks:
  frss-net:
    driver: bridge
