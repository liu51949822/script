version: '3.8'

services:
  n8n:
    image: n8nio/n8n:latest
    container_name: n8n
    restart: always
    environment:
      N8N_HOST: localhost
      N8N_PORT: 5678
      N8N_PROTOCOL: http
      WEBHOOK_URL: http://localhost:5678
      DB_TYPE: sqlite
    ports:
      - "5678:5678"
    volumes:
      - ./n8n-data:/home/node/.n8n
    networks:
      - n8n-net

networks:
  n8n-net:
    driver: bridge
