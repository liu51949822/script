version: '3.8'

services:
  jellyfin:
    image: jellyfin/jellyfin:latest
    container_name: jellyfin
    restart: always
    environment:
      PUID: 1000
      PGID: 1000
      TZ: Asia/Shanghai
    ports:
      - "8096:8096"
      - "8920:8920"
    volumes:
      - ./jellyfin-config:/config
      - ./jellyfin-cache:/cache
      - ./media:/media:ro
    networks:
      - jf-net
    devices:
      - /dev/dri:/dev/dri

networks:
  jf-net:
    driver: bridge
