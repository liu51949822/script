version: '3.8'

services:
  homeassistant:
    image: ghcr.io/home-assistant/home-assistant:stable
    container_name: home-assistant
    restart: always
    environment:
      TZ: Asia/Shanghai
    ports:
      - "8123:8123"
    volumes:
      - ./ha-config:/config
    networks:
      - ha-net
    privileged: true

networks:
  ha-net:
    driver: bridge
